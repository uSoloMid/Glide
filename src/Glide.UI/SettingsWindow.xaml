<Window x:Class="Glide.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Glide Settings"
        Width="920" Height="660" MinWidth="780" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="18,20,0,18">
                    <Grid Width="30" Height="30">
                        <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                                 Width="22" Height="22" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <Line X1="19" Y1="19" X2="28" Y2="28"
                              Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Grid>
                    <TextBlock Text="Glide" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel>
                    <RadioButton x:Name="NavGeneral" Style="{StaticResource NavItem}" Content="General"
                                 IsChecked="True" Checked="OnNavChecked" Tag="General" />
                    <RadioButton Style="{StaticResource NavItem}" Content="Zoom"
                                 Checked="OnNavChecked" Tag="Zoom" />
                    <RadioButton Style="{StaticResource NavItem}" Content="Mouse"
                                 Checked="OnNavChecked" Tag="Mouse" />
                    <RadioButton Style="{StaticResource NavItem}" Content="Performance"
                                 Checked="OnNavChecked" Tag="Performance" />
                    <RadioButton Style="{StaticResource NavItem}" Content="Applications"
                                 Checked="OnNavChecked" Tag="Applications" />
                    <RadioButton Style="{StaticResource NavItem}" Content="Advanced"
                                 Checked="OnNavChecked" Tag="Advanced" />
                    <RadioButton Style="{StaticResource NavItem}" Content="About"
                                 Checked="OnNavChecked" Tag="About" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Content ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="28,22,28,22">
            <Grid>

                <!-- General -->
                <StackPanel x:Name="PanelGeneral">
                    <TextBlock Style="{StaticResource PageTitle}" Text="General" />

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding Enabled}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Enable Glide" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Master switch for the zoom engine." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding TemporaryMode}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Temporary zoom" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Return smoothly to 100% when the modifier key is released. Turn off for persistent zoom." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding AnimateReturn}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Animate return" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Ease back to 100% instead of jumping instantly." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Start with Windows" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Launch silently in the tray at sign-in." />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Zoom -->
                <StackPanel x:Name="PanelZoom" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Zoom" />

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding MaxZoomPercent, StringFormat={}{0:0}%}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Maximum zoom" />
                            </DockPanel>
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="120" Maximum="1000" TickFrequency="10" IsSnapToTickEnabled="True"
                                    Value="{Binding MaxZoomPercent}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding ZoomSpeed, StringFormat={}{0:0.0}×}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Zoom speed" />
                            </DockPanel>
                            <TextBlock Style="{StaticResource SettingDesc}"
                                       Text="How much each wheel tick zooms." />
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="0.1" Maximum="3" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding ZoomSpeed}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding AnimationDurationMs, StringFormat={}{0:0} ms}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Animation duration" />
                            </DockPanel>
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="50" Maximum="1000" TickFrequency="10" IsSnapToTickEnabled="True"
                                    Value="{Binding AnimationDurationMs}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                      ItemsSource="{Binding Curves}" SelectedItem="{Binding SelectedCurve}" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Animation curve" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Easing used when returning to 100%." />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Mouse -->
                <StackPanel x:Name="PanelMouse" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Mouse" />

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Right" Style="{StaticResource DarkCombo}"
                                      ItemsSource="{Binding Modifiers}" SelectedItem="{Binding SelectedModifier}" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Activation key" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Hold this key and scroll to zoom." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding ScrollSensitivity, StringFormat={}{0:0.0}×}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Scroll sensitivity" />
                            </DockPanel>
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="0.1" Maximum="3" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding ScrollSensitivity}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding PanWithMiddleButton}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Pan with middle button" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="While zoomed, hold the middle mouse button to drag the view." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding PanSpeed, StringFormat={}{0:0.0}×}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Pan speed" />
                            </DockPanel>
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="0.1" Maximum="3" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Value="{Binding PanSpeed}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding DoubleTapReset}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Double-tap to reset" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Press the activation key twice quickly to snap back to 100%." />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Performance -->
                <StackPanel x:Name="PanelPerformance" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Performance" />

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding VSync}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="VSync" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Sync rendering to the monitor's refresh rate. Recommended: on." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding MaxFps, StringFormat={}{0:0} fps}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Frame rate limit" />
                            </DockPanel>
                            <TextBlock Style="{StaticResource SettingDesc}"
                                       Text="Applies only when VSync is off." />
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="30" Maximum="480" TickFrequency="10" IsSnapToTickEnabled="True"
                                    Value="{Binding MaxFps}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Applications -->
                <StackPanel x:Name="PanelApplications" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Applications" />
                    <TextBlock Style="{StaticResource SettingDesc}" Margin="0,0,0,12"
                               Text="Glide never activates while any of these applications is in the foreground (e.g. games or design tools with their own Ctrl+wheel zoom)." />

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}"
                                        Content="Add" Margin="8,0,0,0" Click="OnAddExclusion" />
                                <TextBox x:Name="ExclusionBox" Style="{StaticResource DarkTextBox}"
                                         Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnExclusionKeyDown"
                                         ToolTip="Process name, e.g. valorant.exe" />
                            </DockPanel>
                            <ListBox Style="{StaticResource DarkList}" Margin="0,10,0,0" MaxHeight="300"
                                     ItemsSource="{Binding Exclusions}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                                                    Content="Remove" Padding="10,3" FontSize="12"
                                                    Click="OnRemoveExclusion" Tag="{Binding}" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextBrush}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Advanced -->
                <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Advanced" />

                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding ZoomAllMonitors}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Zoom every monitor" />
                                <TextBlock Style="{StaticResource SettingDesc}"
                                           Text="Zoom all displays at once instead of only the one under the cursor." />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource SettingTitle}"
                                           Text="{Binding MinZoomPercent, StringFormat={}{0:0}%}" />
                                <TextBlock Style="{StaticResource SettingTitle}" Text="Minimum zoom" />
                            </DockPanel>
                            <TextBlock Style="{StaticResource SettingDesc}"
                                       Text="Floor of the zoom range. 100% = normal desktop." />
                            <Slider Style="{StaticResource AccentSlider}" Margin="0,10,0,0"
                                    Minimum="100" Maximum="400" TickFrequency="5" IsSnapToTickEnabled="True"
                                    Value="{Binding MinZoomPercent}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SubtleButton}" Content="Open settings folder"
                                    Click="OnOpenSettingsFolder" />
                            <Button Style="{StaticResource SubtleButton}" Content="Reset to defaults"
                                    Margin="8,0,0,0" Click="OnResetDefaults" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- About -->
                <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource PageTitle}" Text="About" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SettingTitle}" FontSize="17"
                                       Text="{Binding VersionText}" />
                            <TextBlock Style="{StaticResource SettingDesc}" Margin="0,8,0,0"
                                       Text="Smooth, cursor-centered zoom for any Windows PC — the fluid Precision-Touchpad zoom feel, with a regular mouse. GPU-accelerated, low latency, no Windows Magnifier involved." />
                            <TextBlock Style="{StaticResource SettingDesc}" Margin="0,10,0,0"
                                       Text="Hold the activation key and scroll to zoom toward the cursor. Release to glide back." />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
